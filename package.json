{
  "name": "habitat",
  "version": "0.1.0",
  "description": "A small Bun and TypeScript command-line app.",
  "type": "module",
  "bin": {
    "habitat": "./src/index.ts"
  },
  "scripts": {
    "habitat": "bun run src/index.ts",
    "dev": "bun run src/index.ts",
    "server": "bun run src/server.ts",
    "start": "bun run src/index.ts",
    "dashboard:dev": "vite",
    "dashboard:build": "vite build",
    "dashboard:preview": "vite preview",
    "test": "bun test",
    "test:web": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "hono": "^4.12.29",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
